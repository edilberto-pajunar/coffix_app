{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "seed:products": "npm run build && node lib/script/products/generate_products.js",
    "serve:dev": "npm run build && GOOGLE_APPLICATION_CREDENTIALS=$(pwd)/service_account_dev.json firebase emulators:start --only functions",
    "serve:prod": "npm run build && GOOGLE_APPLICATION_CREDENTIALS=$(pwd)/service_account_prod.json firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "deploy:dev": "firebase deploy --only functions --project coffix-app-dev",
    "deploy:prod": "firebase deploy --only functions --project coffix-app-prod",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.4.1",
    "typescript": "^5.7.3"
  },
  "private": true
}
